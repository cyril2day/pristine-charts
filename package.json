{
  "name": "pristine-charts",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./area-chart": {
      "import": "./dist/area-chart/index.js",
      "require": "./dist/area-chart/index.cjs"
    },
    "./bar-chart": {
      "import": "./dist/bar-chart/index.js",
      "require": "./dist/bar-chart/index.cjs"
    },
    "./box-plot": {
      "import": "./dist/box-plot/index.js",
      "require": "./dist/box-plot/index.cjs"
    },
    "./bullet-chart": {
      "import": "./dist/bullet-chart/index.js",
      "require": "./dist/bullet-chart/index.cjs"
    },
    "./histogram-chart": {
      "import": "./dist/histogram-chart/index.js",
      "require": "./dist/histogram-chart/index.cjs"
    },
    "./kpi-card": {
      "import": "./dist/kpi-card/index.js",
      "require": "./dist/kpi-card/index.cjs"
    },
    "./line-chart": {
      "import": "./dist/line-chart/index.js",
      "require": "./dist/line-chart/index.cjs"
    },
    "./pie-donut-chart": {
      "import": "./dist/pie-donut-chart/index.js",
      "require": "./dist/pie-donut-chart/index.cjs"
    },
    "./progress-bar": {
      "import": "./dist/progress-bar/index.js",
      "require": "./dist/progress-bar/index.cjs"
    },
    "./ranked-list": {
      "import": "./dist/ranked-list/index.js",
      "require": "./dist/ranked-list/index.cjs"
    },
    "./scatter-plot": {
      "import": "./dist/scatter-plot/index.js",
      "require": "./dist/scatter-plot/index.cjs"
    },
    "./sparkline": {
      "import": "./dist/sparkline/index.js",
      "require": "./dist/sparkline/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsup && sass --load-path=node_modules src/styles/demo.scss dist/styles.css",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "test": "vitest run",
    "preview": "vite preview"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "pristine-styles": "^0.1.1",
    "ramda": "^0.30.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/d3": "^7.4.3",
    "@types/node": "^24.12.3",
    "@types/ramda": "^0.30.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^25.0.1",
    "sass": "^1.77.5",
    "tsup": "^8.1.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.8"
  }
}
