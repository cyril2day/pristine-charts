{
  "name": "pristine-charts",
  "version": "0.1.4",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./area-chart": {
      "types": "./dist/area-chart/index.d.ts",
      "import": "./dist/area-chart/index.js",
      "require": "./dist/area-chart/index.cjs"
    },
    "./bar-chart": {
      "types": "./dist/bar-chart/index.d.ts",
      "import": "./dist/bar-chart/index.js",
      "require": "./dist/bar-chart/index.cjs"
    },
    "./box-plot": {
      "types": "./dist/box-plot/index.d.ts",
      "import": "./dist/box-plot/index.js",
      "require": "./dist/box-plot/index.cjs"
    },
    "./bullet-chart": {
      "types": "./dist/bullet-chart/index.d.ts",
      "import": "./dist/bullet-chart/index.js",
      "require": "./dist/bullet-chart/index.cjs"
    },
    "./funnel-chart": {
      "types": "./dist/funnel-chart/index.d.ts",
      "import": "./dist/funnel-chart/index.js",
      "require": "./dist/funnel-chart/index.cjs"
    },
    "./gauge-chart": {
      "types": "./dist/gauge-chart/index.d.ts",
      "import": "./dist/gauge-chart/index.js",
      "require": "./dist/gauge-chart/index.cjs"
    },
    "./histogram-chart": {
      "types": "./dist/histogram-chart/index.d.ts",
      "import": "./dist/histogram-chart/index.js",
      "require": "./dist/histogram-chart/index.cjs"
    },
    "./kpi-card": {
      "types": "./dist/kpi-card/index.d.ts",
      "import": "./dist/kpi-card/index.js",
      "require": "./dist/kpi-card/index.cjs"
    },
    "./line-chart": {
      "types": "./dist/line-chart/index.d.ts",
      "import": "./dist/line-chart/index.js",
      "require": "./dist/line-chart/index.cjs"
    },
    "./pie-donut-chart": {
      "types": "./dist/pie-donut-chart/index.d.ts",
      "import": "./dist/pie-donut-chart/index.js",
      "require": "./dist/pie-donut-chart/index.cjs"
    },
    "./progress-bar": {
      "types": "./dist/progress-bar/index.d.ts",
      "import": "./dist/progress-bar/index.js",
      "require": "./dist/progress-bar/index.cjs"
    },
    "./ranked-list": {
      "types": "./dist/ranked-list/index.d.ts",
      "import": "./dist/ranked-list/index.js",
      "require": "./dist/ranked-list/index.cjs"
    },
    "./scatter-plot": {
      "types": "./dist/scatter-plot/index.d.ts",
      "import": "./dist/scatter-plot/index.js",
      "require": "./dist/scatter-plot/index.cjs"
    },
    "./sparkline": {
      "types": "./dist/sparkline/index.d.ts",
      "import": "./dist/sparkline/index.js",
      "require": "./dist/sparkline/index.cjs"
    },
    "./variance-chart": {
      "types": "./dist/variance-chart/index.d.ts",
      "import": "./dist/variance-chart/index.js",
      "require": "./dist/variance-chart/index.cjs"
    },
    "./tokens.css": "./dist/tokens.css",
    "./area-chart.css": "./dist/area-chart/AreaChart.css",
    "./bar-chart.css": "./dist/bar-chart/BarChart.css",
    "./box-plot.css": "./dist/box-plot/BoxPlot.css",
    "./bullet-chart.css": "./dist/bullet-chart/BulletChart.css",
    "./chart-error.css": "./dist/chart-error/ChartError.css",
    "./funnel-chart.css": "./dist/funnel-chart/FunnelChart.css",
    "./gauge-chart.css": "./dist/gauge-chart/GaugeChart.css",
    "./histogram-chart.css": "./dist/histogram-chart/HistogramChart.css",
    "./kpi-card.css": "./dist/kpi-card/KPICard.css",
    "./line-chart.css": "./dist/line-chart/LineChart.css",
    "./pie-donut-chart.css": "./dist/pie-donut-chart/PieDonutChart.css",
    "./progress-bar.css": "./dist/progress-bar/ProgressBar.css",
    "./ranked-list.css": "./dist/ranked-list/RankedList.css",
    "./scatter-plot.css": "./dist/scatter-plot/ScatterPlot.css",
    "./sparkline.css": "./dist/sparkline/Sparkline.css",
    "./variance-chart.css": "./dist/variance-chart/VarianceChart.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build:lib": "tsup && pnpm build:css",
    "build:css": "sass --load-path=node_modules src/styles/tokens.scss dist/tokens.css --no-source-map && sass src/area-chart/AreaChart.scss dist/area-chart/AreaChart.css --no-source-map && sass src/bar-chart/BarChart.scss dist/bar-chart/BarChart.css --no-source-map && sass src/box-plot/BoxPlot.scss dist/box-plot/BoxPlot.css --no-source-map && sass src/bullet-chart/BulletChart.scss dist/bullet-chart/BulletChart.css --no-source-map && sass src/chart-error/ChartError.scss dist/chart-error/ChartError.css --no-source-map && sass src/funnel-chart/FunnelChart.scss dist/funnel-chart/FunnelChart.css --no-source-map && sass src/gauge-chart/GaugeChart.scss dist/gauge-chart/GaugeChart.css --no-source-map && sass src/histogram-chart/HistogramChart.scss dist/histogram-chart/HistogramChart.css --no-source-map && sass src/kpi-card/KPICard.scss dist/kpi-card/KPICard.css --no-source-map && sass src/line-chart/LineChart.scss dist/line-chart/LineChart.css --no-source-map && sass src/pie-donut-chart/PieDonutChart.scss dist/pie-donut-chart/PieDonutChart.css --no-source-map && sass src/progress-bar/ProgressBar.scss dist/progress-bar/ProgressBar.css --no-source-map && sass src/ranked-list/RankedList.scss dist/ranked-list/RankedList.css --no-source-map && sass src/scatter-plot/ScatterPlot.scss dist/scatter-plot/ScatterPlot.css --no-source-map && sass src/sparkline/Sparkline.scss dist/sparkline/Sparkline.css --no-source-map && sass src/variance-chart/VarianceChart.scss dist/variance-chart/VarianceChart.css --no-source-map",
    "build:site": "vite build --mode pages",
    "build": "pnpm build:lib && pnpm build:site",
    "prepublishOnly": "pnpm build:lib",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "test": "vitest run",
    "preview": "vite preview"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "ramda": "^0.30.1"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/d3": "^7.4.3",
    "@types/node": "^24.12.3",
    "@types/ramda": "^0.30.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^25.0.1",
    "sass": "^1.77.5",
    "tsup": "^8.1.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.8",
    "pristine-styles": "^0.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
